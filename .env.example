# Vibecraft environment variables
# Copy to .env and fill in your values

# Server ports
VIBECRAFT_PORT=4003
VIBECRAFT_CLIENT_PORT=4002

# Scenario generation (required for Create Scenario and Regenerate)
OPENAI_API_KEY=sk-...
SD_URL=http://localhost:7860

# Optional overrides
# VIBECRAFT_TMUX_SESSION=claude
# VIBECRAFT_DEBUG=false
